{
  "manifest_version": 3,
  "name": "ApplyThis",
  "version": "1.0",

  "description": "Companion extension for ApplyThis",


  "permissions": [
    "contextMenus",
    "storage",
    "notifications",
    "activeTab"
  ],
  
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/bitmap.svg"
    }
  },
  "icons": {
    "48": "icons/bitmap.svg"
  },

  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/jobs/*"],
      "js": ["content/linkedin.js"]
	  }
  ]
}